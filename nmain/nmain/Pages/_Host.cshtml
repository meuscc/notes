@page "/"
@namespace nmain.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
  Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>nmain</title>
  <base href="~/"/>
  <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css"/>
  <link href="css/site.css" rel="stylesheet"/>
  <link href="nmain.styles.css" rel="stylesheet"/>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.13.11/dist/katex.min.css" integrity="sha384-Um5gpz1odJg5Z4HAmzPtgZKdTBHZdw8S29IecapCSB31ligYPhHQZMIlWLYQGVoc" crossorigin="anonymous">

</head>
<body>
<component type="typeof(App)" render-mode="ServerPrerendered"/>

<script src="_framework/blazor.server.js" autostart="false"></script>

    <script>
      Blazor.start().then(function () {
        var customScript1 = document.createElement('script');
        var customScript2 = document.createElement('script');
        customScript1.setAttribute('src', 'https://cdn.jsdelivr.net/npm/katex@0.13.11/dist/katex.min.js');
        customScript2.setAttribute('src', 'https://cdn.jsdelivr.net/npm/katex@0.13.11/dist/contrib/auto-render.min.js');
        document.head.appendChild(customScript1);
        document.head.appendChild(customScript2);
        customScript2.onload  = () => {


        renderMathInElement(document.body, {

          // customised options
          // • auto-render specific keys, e.g.:
          delimiters: [
              {left: '$$', right: '$$', display: true},
              {left: '$', right: '$', display: false},
              {left: '\\(', right: '\\)', display: false},
              {left: '\\[', right: '\\]', display: true}
          ],
          // • rendering keys, e.g.:
          throwOnError : true
        });
        }

      });
    </script>


</body>
</html>
